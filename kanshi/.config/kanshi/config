# PROFILE 1: All three screens (Laptop open)
profile {
    output DP-12 mode 2560x1440 position 0,0
    output DP-10 mode 2560x1440 position 2560,0
    output eDP-2 mode 2560x1600 position 2560,1440
}

# PROFILE 2: Closed Lid / Dual Monitor (Laptop disabled)
profile {
    output DP-12 mode 2560x1440 position 0,0
    output DP-10 mode 2560x1440 position 2560,0
    output eDP-2 disable
}

# PROFILE 3: Laptop only (On the go)
profile {
    output eDP-2 mode 2560x1600 position 0,0
}
